@model ĐACN.KhachHang
@{
    ViewBag.Title = "Chi tiết người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    bool isEdit = ViewBag.EditMode == true; // flag chỉnh sửa
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-circle"></i> Thông tin chi tiết người dùng</h4>
            <a href="@Url.Action("DanhSachNguoiDung", "Admin")" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @using (Html.BeginForm("SuaNguoiDung", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaKH)

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên khách hàng</label>
                        @if (isEdit)
                        {
                            @Html.TextBoxFor(m => m.TenKH, new { @class = "form-control", required = "required" })
                        }
                        else
                        {
                            <p class="form-control-plaintext">@Model.TenKH</p>
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        @if (isEdit)
                        {
                            @Html.TextBoxFor(m => m.SDT, new { @class = "form-control" })
                        }
                        else
                        {
                            <p class="form-control-plaintext">@Model.SDT</p>
                        }
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Địa chỉ</label>
                        @if (isEdit)
                        {
                            @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control" })
                        }
                        else
                        {
                            <p class="form-control-plaintext">@Model.DiaChi</p>
                        }
                    </div>
                </div>

                <hr />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên đăng nhập</label>
                        @if (isEdit)
                        {
                            @Html.TextBox("TenDangNhap", Model.TaiKhoan != null ? Model.TaiKhoan.TenDangNhap : "", new { @class = "form-control", required = "required" })
                        }
                        else
                        {
                            <p class="form-control-plaintext">
                                @(Model.TaiKhoan != null ? Model.TaiKhoan.TenDangNhap : "Chưa có tài khoản")
                            </p>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        @if (isEdit)
                        {
                            <input type="text" name="MatKhau" value="@(Model.TaiKhoan?.MatKhau)" class="form-control" placeholder="Nhập mật khẩu mới..." />
                        }
                        else
                        {
                            <p class="form-control-plaintext">@(Model.TaiKhoan != null ? Model.TaiKhoan.MatKhau : "Chưa có")</p>
                        }
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Vai trò</label>
                        @if (isEdit)
                        {
                            <select name="VaiTro" class="form-select">
                                <option value="KhachHang" @(Model.TaiKhoan?.VaiTro == "KhachHang" ? "selected" : "")>Khách hàng</option>
                                <option value="Admin" @(Model.TaiKhoan?.VaiTro == "Admin" ? "selected" : "")>Admin</option>
                            </select>
                        }
                        else
                        {
                            <p class="form-control-plaintext">
                                @(Model.TaiKhoan != null ? Model.TaiKhoan.VaiTro : "Không xác định")
                            </p>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Trạng thái tài khoản</label>
                        @if (isEdit)
                        {
                            <select name="TrangThai" class="form-select">
                                <option value="true" @(Model.TaiKhoan?.TrangThai == true ? "selected" : "")>Hoạt động</option>
                                <option value="false" @(Model.TaiKhoan?.TrangThai == false ? "selected" : "")>Bị khóa</option>
                            </select>
                        }
                        else
                        {
                            <p class="form-control-plaintext">
                                @if (Model.TaiKhoan?.TrangThai == true)
                                {
                                    <span class="text-success fw-bold">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold">Bị khóa</span>
                                }
                            </p>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    @if (!isEdit)
                    {
                        <a href="@Url.Action("ChiTietNguoiDung", "Admin", new { id = Model.MaKH, edit = true })" class="btn btn-warning">
                            <i class="bi bi-pencil-square"></i> Sửa thông tin
                        </a>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                        <a href="@Url.Action("ChiTietNguoiDung", "Admin", new { id = Model.MaKH })" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Hủy
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">