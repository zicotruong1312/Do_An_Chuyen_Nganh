@model ĐACN.Shipper
@{
    ViewBag.Title = "Chi tiết người giao hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    bool isEdit = ViewBag.EditMode == true;

    var taiKhoan = Model.TaiKhoan; // biến tạm để tránh proxy EF
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-truck"></i> Thông tin chi tiết Shipper</h4>
            <a href="@Url.Action("DanhSachShipper", "Admin")" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("SuaShipper", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.HiddenFor(m => m.MaShipper)

                <div class="row mb-3">
                    <div class="col-md-4 text-center border-end">
                        <div class="position-relative d-inline-block">
                            <img src="@(string.IsNullOrEmpty(Model.HinhAnh)
                                ? Url.Content("~/Content/images/default-avatar.png")
                                : Url.Content("~" + Model.HinhAnh))"
                                 alt="avatar"
                                 class="rounded-circle border mb-2"
                                 width="150" height="150"
                                 style="object-fit: cover;"
                                 id="previewAvatar" />

                            @if (isEdit)
                            {
                                <label for="HinhShipperFile" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2"
                                       style="cursor:pointer; transform: translate(20%, 20%);">
                                    <i class="bi bi-plus-lg"></i>
                                </label>
                                <input type="file" id="HinhShipperFile" name="HinhShipperFile" accept="image/*" class="d-none" onchange="previewImage(event)" />
                            }
                        </div>

                        <h5 class="fw-bold mt-2">@Model.TenShipper</h5>
                        <p class="text-muted mb-1"><i class="bi bi-card-text"></i> Mã: @Model.MaShipper</p>
                        <p class="text-muted"><i class="bi bi-telephone"></i> @Model.SDT</p>
                    </div>

                    <div class="col-md-8">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên Shipper</label>
                                @if (isEdit)
                                {
                                    @Html.TextBoxFor(m => m.TenShipper, new { @class = "form-control", required = "required" })
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@Model.TenShipper</p>
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                @if (isEdit)
                                {
                                    @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", required = "required" })
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@Model.SDT</p>
                                }
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Biển số xe</label>
                                @if (isEdit)
                                {
                                    @Html.TextBoxFor(m => m.BienSoXe, new { @class = "form-control" })
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@Model.BienSoXe</p>
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                @if (isEdit)
                                {
                                    <input type="text" name="TenDangNhap" value="@(taiKhoan?.TenDangNhap ?? "")" class="form-control" />
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@((taiKhoan != null) ? taiKhoan.TenDangNhap : "Chưa có")</p>
                                }
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                @if (isEdit)
                                {
                                    <div class="input-group">
                                        <input type="password" name="MatKhau" id="matKhauInput"
                                               value="@(taiKhoan?.MatKhau ?? "")" class="form-control" required />
                                        <button type="button" class="btn btn-outline-secondary"
                                                onclick="togglePassword()" title="Hiển thị / Ẩn mật khẩu">
                                            <i class="bi bi-eye" id="toggleIcon"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@((taiKhoan != null) ? taiKhoan.MatKhau : "Chưa có")</p>
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Vai trò</label>
                                @if (isEdit)
                                {
                                    <select name="VaiTro" class="form-select">
                                        <option value="Shipper" @(taiKhoan?.VaiTro == "Shipper" ? "selected" : "")>Shipper</option>
                                    </select>
                                }
                                else
                                {
                                    <p class="form-control-plaintext">@((taiKhoan != null) ? taiKhoan.VaiTro : "Không xác định")</p>
                                }
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Trạng thái tài khoản</label>
                                @if (isEdit)
                                {
                                    <select name="TrangThai" class="form-select">
                                        <option value="true" @(taiKhoan?.TrangThai == true ? "selected" : "")>Hoạt động</option>
                                        <option value="false" @(taiKhoan?.TrangThai == false ? "selected" : "")>Bị khóa</option>
                                    </select>
                                }
                                else
                                {
                                    <p class="form-control-plaintext">
                                        @if (taiKhoan?.TrangThai == true)
                                        {
                                            <span class="text-success fw-bold">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">Bị khóa</span>
                                        }
                                    </p>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            @if (!isEdit)
                            {
                                <a href="@Url.Action("ChiTietShipper", "Admin", new { id = Model.MaShipper, edit = true })" class="btn btn-warning">
                                    <i class="bi bi-pencil-square"></i> Sửa thông tin
                                </a>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-save"></i> Lưu thay đổi
                                </button>
                                <a href="@Url.Action("ChiTietShipper", "Admin", new { id = Model.MaShipper })" class="btn btn-secondary">
                                    <i class="bi bi-x-circle"></i> Hủy
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-3 text-center fw-bold">@TempData["Message"]</div>
    }
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<script>
    function previewImage(event) {
        const input = event.target;
        const reader = new FileReader();
        reader.onload = function () {
            document.getElementById("previewAvatar").src = reader.result;
        };
        reader.readAsDataURL(input.files[0]);
    }

    function togglePassword() {
        const passwordInput = document.getElementById("matKhauInput");
        const icon = document.getElementById("toggleIcon");
        if (passwordInput.type === "password") {
            passwordInput.type = "text";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        } else {
            passwordInput.type = "password";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>
