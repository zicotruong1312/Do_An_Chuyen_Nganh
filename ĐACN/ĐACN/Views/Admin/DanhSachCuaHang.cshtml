@model IEnumerable<ĐACN.NhaHang>

@{
    ViewBag.Title = "Danh sách cửa hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 class="text-center mb-4 fw-bold"><i class="bi bi-shop"></i> Danh sách cửa hàng</h2>

<div class="d-flex justify-content-between mb-3 flex-wrap">
    <form method="get" class="row g-2 w-100 w-md-75">
        <div class="col-md-6">
            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Nhập tên hoặc địa chỉ cửa hàng..." class="form-control" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="Hoạt động" @(ViewBag.Status == "Hoạt động" ? "selected" : "")>Hoạt động</option>
                <option value="Bị khóa" @(ViewBag.Status == "Bị khóa" ? "selected" : "")>Bị khóa</option>
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100"><i class="bi bi-search"></i> Tìm kiếm</button>
        </div>
    </form>

    <a href="@Url.Action("ThemNhaHang", "Admin")" class="btn btn-success mt-2 mt-md-0">
        <i class="bi bi-plus-circle"></i> Thêm mới
    </a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success text-center fw-bold">@TempData["Message"]</div>
}

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark text-center">
        <tr>
            <th>STT</th>
            <th>Tên cửa hàng</th>
            <th>Địa chỉ</th>
            <th>Số điện thoại</th>
            <th>Tên đăng nhập</th>
            <th>Vai trò</th>
            <th>Trạng thái TK</th>
            <th>Chi tiết</th>
            <th>Khóa/Mở</th>
            <th>Xóa</th>
        </tr>
    </thead>
    <tbody>
        @{
            int stt = 1;
        }
        @foreach (var nh in Model)
        {
            <tr class="text-center">
                <td>@stt</td>
                <td>@nh.TenNH</td>
                <td>@nh.DiaChi</td>
                <td>@nh.SDT</td>
                <td>@(nh.TaiKhoan?.TenDangNhap ?? "Chưa có")</td>
                <td>@(nh.TaiKhoan?.VaiTro ?? "-")</td>
                <td>
                    @if (nh.TaiKhoan?.TrangThai == true)
                    {
                        <span class="text-success fw-bold">Hoạt động</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold">Bị khóa</span>
                    }
                </td>
                <td>
                    <a href="@Url.Action("ChiTietNhaHang", "Admin", new { id = nh.MaNH })" class="btn btn-info btn-sm">
                        <i class="bi bi-eye"></i> Xem
                    </a>
                </td>
                <td>
                    <form action="@Url.Action("DoiTrangThaiNhaHang", "Admin")" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@nh.MaNH" />
                        @if (nh.TaiKhoan?.TrangThai == true)
                        {
                            <button type="submit" class="btn btn-warning btn-sm">
                                <i class="bi bi-lock"></i> Khóa
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-unlock"></i> Mở
                            </button>
                        }
                    </form>
                </td>
                <td>
                    <form action="@Url.Action("XoaNhaHang", "Admin")" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa cửa hàng này không?');">
                        <input type="hidden" name="id" value="@nh.MaNH" />
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Xóa
                        </button>
                    </form>
                </td>
            </tr>
            stt++;
        }
    </tbody>
</table>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">