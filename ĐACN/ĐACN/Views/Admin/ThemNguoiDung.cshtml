@model ĐACN.KhachHang

@{
    ViewBag.Title = "Thêm khách hàng mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-plus-fill"></i> Thêm người dùng mới</h4>
            <a href="@Url.Action("DanhSachNguoiDung", "Admin")" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("ThemNguoiDung", "Admin", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaKH)

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Họ và tên</label>
                        @Html.TextBoxFor(m => m.TenKH, new { @class = "form-control", placeholder = "Nhập họ tên người dùng...", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", placeholder = "Nhập số điện thoại...", required = "required" })
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", placeholder = "Nhập địa chỉ người dùng...", required = "required" })
                </div>

                <hr />
                <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-person-lock"></i> Thông tin tài khoản</h5>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên đăng nhập</label>
                        <input type="text" name="TenDangNhap" class="form-control" placeholder="Nhập tên đăng nhập..." required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <input type="password" name="MatKhau" class="form-control" placeholder="Nhập mật khẩu..." required />
                    </div>
                </div>

                <!-- Xóa các trường VaiTro và TrangThai, controller gán cứng -->

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> Lưu người dùng
                    </button>
                    <a href="@Url.Action("DanhSachNguoiDung", "Admin")" class="btn btn-secondary px-4">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">