@model ĐACN.NhaHang

@{
    ViewBag.Title = "Thêm cửa hàng mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-shop"></i> Thêm cửa hàng mới</h4>
            <a href="@Url.Action("DanhSachCuaHang", "Admin")" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("ThemNhaHang", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaNH)

                <div class="row mb-3">
                    <!-- Cột trái: Ảnh cửa hàng -->
                    <div class="col-md-4 text-center border-end">
                        <img id="previewAvatar"
                             src="~/images/default-restaurant.png"
                             alt="Hình cửa hàng"
                             class="rounded border mb-3"
                             width="200" height="200" />
                        <h6 class="text-muted">Ảnh đại diện cửa hàng</h6>

                        <input type="file" name="HinhNhaHangFile"
                               accept="image/*"
                               class="form-control mt-2"
                               onchange="previewImage(event)" />
                    </div>

                    <!-- Cột phải: Thông tin nhà hàng -->
                    <div class="col-md-8">
                        <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-info-circle"></i> Thông tin cửa hàng</h5>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên cửa hàng</label>
                                @Html.TextBoxFor(m => m.TenNH, new { @class = "form-control", placeholder = "Nhập tên cửa hàng...", required = "required" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", placeholder = "Nhập số điện thoại...", required = "required" })
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", placeholder = "Nhập địa chỉ cửa hàng...", required = "required" })
                        </div>

                        <hr />
                        <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-person-vcard"></i> Tài khoản đăng nhập</h5>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                <input type="text" name="TenDangNhap" class="form-control" placeholder="Tên đăng nhập cho cửa hàng..." required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                <input type="password" name="MatKhau" class="form-control" placeholder="Nhập mật khẩu..." required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Trạng thái cửa hàng</label>
                                <select name="TrangThai" class="form-select">
                                    <option value="Đang mở cửa">Đang mở cửa</option>
                                    <option value="Đã đóng cửa">Đã đóng cửa</option>
                                </select>
                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-save"></i> Lưu cửa hàng
                            </button>
                            <a href="@Url.Action("DanhSachCuaHang", "Admin")" class="btn btn-secondary px-4">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-3 text-center fw-bold">@TempData["Message"]</div>
    }
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<script>
    function previewImage(event) {
        const output = document.getElementById('previewAvatar');
        output.src = URL.createObjectURL(event.target.files[0]);
        output.onload = function () {
            URL.revokeObjectURL(output.src);
        }
    }
</script>