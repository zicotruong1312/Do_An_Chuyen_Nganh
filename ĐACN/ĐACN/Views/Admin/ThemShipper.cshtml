@model ĐACN.Shipper
@{
    ViewBag.Title = "Thêm người giao hàng mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-plus"></i> Thêm Shipper mới</h4>
            <a href="@Url.Action("DanhSachShipper", "Admin")" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("ThemShipper", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="row mb-3">
                    <!-- Cột trái: Ảnh đại diện -->
                    <div class="col-md-4 text-center border-end">
                        <img id="previewAvatar"
                             src="~/Content/images/default-avatar.png"
                             alt="avatar"
                             class="rounded-circle border mb-3"
                             width="150" height="150" />
                        <h6 class="text-muted">Ảnh đại diện Shipper</h6>

                        <input type="file" name="HinhShipperFile"
                               accept="image/*"
                               class="form-control mt-2"
                               onchange="previewImage(event)" />
                    </div>

                    <!-- Cột phải: Thông tin Shipper -->
                    <div class="col-md-8">
                        <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-person"></i> Thông tin cá nhân</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên Shipper</label>
                                @Html.TextBoxFor(m => m.TenShipper, new { @class = "form-control", required = "required", placeholder = "Nhập tên người giao hàng" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", required = "required", placeholder = "VD: 0901234567" })
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Biển số xe</label>
                                @Html.TextBoxFor(m => m.BienSoXe, new { @class = "form-control", placeholder = "VD: 59X1-12345" })
                            </div>
                        </div>

                        <hr />

                        <!-- Thông tin tài khoản -->
                        <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-person-vcard"></i> Thông tin tài khoản</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                <input type="text" name="TenDangNhap" class="form-control" required placeholder="Tên đăng nhập hệ thống" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                <input type="password" name="MatKhau" class="form-control" required placeholder="Nhập mật khẩu" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Vai trò</label>
                                <select name="VaiTro" class="form-select" required>
                                    <option value="Shipper" selected>Shipper</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Trạng thái tài khoản</label>
                                <select name="TrangThai" class="form-select">
                                    <option value="true" selected>Hoạt động</option>
                                    <option value="false">Bị khóa</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-4 text-end">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-plus-circle"></i> Thêm Shipper
                            </button>
                            <a href="@Url.Action("DanhSachShipper", "Admin")" class="btn btn-secondary px-4">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-3 text-center fw-bold">@TempData["Message"]</div>
    }
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<script>
    function previewImage(event) {
        const output = document.getElementById('previewAvatar');
        output.src = URL.createObjectURL(event.target.files[0]);
        output.onload = function () {
            URL.revokeObjectURL(output.src); // giải phóng bộ nhớ
        }
    }
</script>