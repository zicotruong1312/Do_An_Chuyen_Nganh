@model ĐACN.Models.TrangChuViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Trang Chủ";
}

<style>
    body {
        font-family: 'Poppins', sans-serif;
        background-color: #fff;
        color: #333;
    }

    .banner {
        background-image: url('/images/banner-food.jpg');
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        height: 400px;
    }

    .banner-overlay {
        background: rgba(0, 0, 0, 0.6);
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .banner-content h1 {
        font-size: 2.8rem;
        font-weight: 700;
        color: #fff;
    }

    .banner-content p {
        font-size: 1.2rem;
        margin-top: 10px;
        color: #fff;
    }

    .search-bar {
        display: flex;
        justify-content: center;
        gap: 10px;
        width: 80%;
        max-width: 700px;
        margin: 0 auto;
    }

        .search-bar input {
            flex: 1;
            padding: 10px;
            border-radius: 8px;
            border: none;
        }

    .section-title {
        font-weight: 700;
        margin-bottom: 25px;
    }

    .category-card {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 10px;
        transition: 0.3s;
    }

        .category-card:hover {
            transform: scale(1.05);
            background: #ffecec;
        }

    .category-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 50%;
    }

    .restaurant-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .restaurant-card:hover {
            transform: scale(1.03);
        }

        .restaurant-card img {
            height: 200px;
            object-fit: cover;
        }

    .feedback-card {
        background: #fff8f8;
        border-radius: 10px;
        padding: 20px;
        font-style: italic;
    }

    .footer {
        background: #222;
        color: #ccc;
        padding: 25px 0;
    }
</style>

<section class="banner">
    <div class="banner-overlay">
        <div class="banner-content text-center">
            <h1>🍜 Đặt món nhanh – Giao tận nơi</h1>
            <p>Khám phá hàng trăm nhà hàng, quán ăn yêu thích quanh bạn!</p>

            <div class="search-bar mt-4">
                <input type="text" class="form-control" placeholder="Nhập món ăn, nhà hàng hoặc địa chỉ giao hàng..." />
                <button class="btn btn-danger">Tìm kiếm</button>
            </div>
        </div>
    </div>
</section>

<section class="container mt-5">
    <h2 class="section-title">🍽️ Danh mục phổ biến</h2>
    @Html.Partial("_DanhMucPartial", Model.DanhMuc)
</section>

<section class="container mt-5">
    <h2 class="section-title">🏙️ Nhà hàng nổi bật</h2>
    @Html.Partial("_NhaHangNoiBatPartial", Model.NhaHang)
</section>

<section class="feedback mt-5">
    <div class="container text-center">
        <h2 class="section-title">💬 Khách hàng nói gì về chúng tôi</h2>
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card feedback-card">
                    <p>“Giao hàng cực nhanh, đồ ăn còn nóng hổi! Rất hài lòng 😋”</p>
                    <h6>- Minh Anh</h6>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feedback-card">
                    <p>“Món ăn đa dạng, tìm quán dễ dàng, thanh toán tiện lợi 👏”</p>
                    <h6>- Đức Huy</h6>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feedback-card">
                    <p>“App thân thiện, đặt hàng chưa bao giờ nhanh như vậy 🚀”</p>
                    <h6>- Thuỷ Tiên</h6>
                </div>
            </div>
        </div>
    </div>
</section>

<footer class="footer mt-5">
    <div class="container text-center">
        <p>© 2025 ZFood Delivery. All rights reserved.</p>
        <p>Hotline: 1900 9999 | Email: support@zfood.vn</p>
    </div>
</footer>

@section scripts{
    <script>
        $(document).ready(function () {
            // Kiểm tra người dùng đã đăng nhập hay chưa
            const isLoggedIn = @((Session["TaiKhoan"] != null).ToString().ToLower());

            // Chặn các link yêu cầu login nếu chưa đăng nhập
            $(".require-login").click(function (e) {
                if (!isLoggedIn) {
                    e.preventDefault();
                    $("#loginModal").modal('show');
                }
            });
        });
    </script>
}