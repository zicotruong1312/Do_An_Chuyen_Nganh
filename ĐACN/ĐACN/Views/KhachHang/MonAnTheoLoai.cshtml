@model ĐACN.Models.MonAnTheoLoaiViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = Model.LoaiMonAn.TenLoai;
}

<style>
    .dish-card {
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
        text-align: center;
        cursor: pointer;

        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

    .dish-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.15);
    }

    .dish-img {
        width: 100%;
        height: 180px;
        object-fit: contain; /* thay đổi từ cover -> contain */
        background-color: #f8f8f8;
        flex-shrink: 0;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
        padding: 8px; /* thêm khoảng trống xung quanh để ảnh không sát viền */
    }

    .dish-body {
        padding: 12px 10px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex-grow: 1;
    }

    .dish-body h5 {
        font-weight: 600;
        margin-bottom: 6px;
        word-wrap: break-word;
    }

    .dish-body p {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 4px;
    }

    .price {
        font-weight: 600;
        color: #d32f2f;
        font-size: 1rem;
    }

    @@media (max-width: 768px) {
        .dish-img {
            height: 140px;
        }
    }
</style>

<div class="container mt-4">
    <h2 class="text-center mb-4 fw-bold">🏠 Nhà Hàng Có Món @Model.LoaiMonAn.TenLoai</h2>

    @if (Model.NhaHang == null || !Model.NhaHang.Any())
    {
        <p class="text-center text-muted mt-3">Chưa có nhà hàng nào có món ăn này.</p>
    }
    else
    {
        <div class="row">
            @foreach (var nh in Model.NhaHang)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-4 d-flex">
                    <div class="dish-card shadow-sm w-100">
                        <a href="@Url.Action("XemMenu", "KhachHang", new { id = nh.MaNH })"
                           style="text-decoration:none; color:inherit;">
                            <img src="~/images/nhahang/@nh.HinhAnh" alt="@nh.TenNH" class="dish-img" />
                            <div class="dish-body">
                                <h5>@nh.TenNH</h5>
                                <p>📍 @nh.DiaChi</p>
                                <p>🛒 @nh.TongLuotMua lượt mua</p>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>