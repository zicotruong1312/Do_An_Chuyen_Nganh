@model IEnumerable<ĐACN.Models.MonAnViewModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var nhaHang = ViewBag.NhaHang as ĐACN.NhaHang;
}

<style>
    .dish-card {
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
        cursor: pointer;
        text-align: center;

        display: flex;              /* bật flex */
        flex-direction: column;     /* sắp xếp theo cột */
        justify-content: space-between; /* giãn đều nội dung */
        height: 100%;               /* chiều cao đầy đủ để đồng bộ */
    }

    .dish-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.15);
    }

    .dish-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
        background-color: #f8f8f8;
        flex-shrink: 0;
    }

    .dish-body {
        padding: 12px 10px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex-grow: 1; /* chiếm không gian còn lại */
    }

    .dish-body h5 {
        font-weight: 600;
        margin-bottom: 6px;
        word-wrap: break-word; /* xuống dòng nếu tên dài */
    }

    .dish-body p {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 4px;
    }

    .price {
        font-weight: 600;
        color: #d32f2f;
        font-size: 1rem;
    }

    @@media (max-width: 768px) {
        .dish-img {
            height: 140px;
        }
    }
</style>

<div class="container mt-4">
    <h2 class="text-center mb-4 fw-bold">🍽️ Menu - @nhaHang.TenNH</h2>

    @if (Model == null || !Model.Any())
    {
        <p class="text-center text-muted mt-3">Hiện chưa có món ăn nào.</p>
    }
    else
    {
        <div class="row">
            @foreach (var m in Model)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-4 d-flex">
                    <div class="dish-card shadow-sm w-100">
                        <img src="~/images/danhmuc/@m.HinhAnh" alt="@m.TenMon" class="dish-img" />
                        <div class="dish-body">
                            <h5>@m.TenMon</h5>
                            <p class="price">@String.Format("{0:N0} đ", m.Gia)</p>
                            <p>@m.MoTa</p>
                            <a href="@Url.Action("ThemVaoGio", "KhachHang", new { id = m.MaMon })"
                               class="btn btn-success btn-sm mt-2">+ Giỏ hàng</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>