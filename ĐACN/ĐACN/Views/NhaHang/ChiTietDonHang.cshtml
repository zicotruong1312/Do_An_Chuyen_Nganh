@model ĐACN.DonHang

@{
    ViewBag.Title = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_LayoutNhaHang.cshtml";
    var chiTiet = ViewBag.ChiTiet as List<ĐACN.ChiTietDonHang>;
}

<div class="container mt-4">
    <h3 class="text-primary mb-3">Chi tiết đơn hàng: @Model.MaDon</h3>

    <div class="card mb-4">
        <div class="card-body">
            <p><strong>Khách hàng:</strong> @Model.KhachHang?.TenKH</p>
            <p><strong>Số điện thoại:</strong> @Model.KhachHang?.SDT</p>
            <p><strong>Địa chỉ:</strong> @Model.KhachHang?.DiaChi</p>
            <p><strong>Ngày đặt:</strong> @Model.ThoiGianDat?.ToString("dd/MM/yyyy HH:mm")</p>
            <p>
                <strong>Trạng thái:</strong>
                @(Model.TrangThai == true ? "Hoàn tất" : "Đang xử lý")
            </p>
            <p><strong>Shipper:</strong> @Model.Shipper?.TenShipper</p>
        </div>
    </div>

    <h5 class="mb-2">Danh sách món ăn</h5>
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Tên món</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @if (chiTiet != null && chiTiet.Count > 0)
            {
                foreach (var item in chiTiet)
                {
                    <tr>
                        <td>@item.MonAn?.TenMon</td>
                        <td>@item.SoLuong</td>
                        <td>@string.Format("{0:N0} đ", item.DonGia)</td>
                        <td>@string.Format("{0:N0} đ", item.SoLuong * item.DonGia)</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end mt-3">
        <h5>Tổng tiền: <strong class="text-danger">@string.Format("{0:N0} đ", Model.TongTien)</strong></h5>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("DanhSachDonHang", "NhaHang")" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>