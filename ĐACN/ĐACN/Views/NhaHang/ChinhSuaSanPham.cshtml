@model ĐACN.MonAn

@{
    ViewBag.Title = "Chỉnh sửa sản phẩm";
    ViewBag.Active = "SanPham";
    Layout = "~/Views/Shared/_LayoutNhaHang.cshtml";
}

<h2>Chỉnh sửa sản phẩm</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@using (Html.BeginForm("ChinhSuaSanPham", "NhaHang", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.MaMon)

    <div class="row">
        <div class="col-md-8">
            <div class="form-group">
                <label for="TenMon">Tên sản phẩm</label>
                @Html.TextBoxFor(m => m.TenMon, new { @class = "form-control", placeholder = "Nhập tên sản phẩm" })
            </div>

            <div class="form-group">
                <label for="Gia">Giá tiền (VNĐ)</label>
                @Html.TextBoxFor(m => m.Gia, new { @class = "form-control", type = "number", min = "0" })
            </div>

            <div class="form-group">
                <label for="MoTa">Mô tả</label>
                @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 3, placeholder = "Nhập mô tả món ăn" })
            </div>

            <div class="form-group">
                <label for="MaLoai">Danh mục</label>
                @Html.DropDownListFor(m => m.MaLoai, (SelectList)ViewBag.MaLoai, "Chọn danh mục", new { @class = "form-control" })
            </div>

            <div class="form-group">
                <label>Trạng thái</label><br />
                <label>
                    @Html.RadioButtonFor(m => m.TrangThai, true, new { id = "TrangThaiConHang" }) Còn hàng
                </label>
                <label style="margin-left:15px;">
                    @Html.RadioButtonFor(m => m.TrangThai, false, new { id = "TrangThaiHetHang" }) Hết hàng
                </label>
            </div>

            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a href="@Url.Action("QuanLySanPham", "NhaHang")" class="btn btn-secondary">Hủy</a>
        </div>

        <div class="col-md-4">
            <label>Hình ảnh hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                <img src="@Url.Content("~/images/monan/" + Model.HinhAnh)" width="150" style="border:1px solid #ccc; padding:4px;" /><br /><br />
            }
            <label>Chọn ảnh mới</label>
            <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" onchange="previewImage(event)" />
            <br />
            <img id="preview" src="#" alt="Xem trước ảnh" style="display:none; max-width:100%; border:1px solid #ccc; padding:4px;" />
        </div>
    </div>
}

@section Scripts {
    <script>
        function previewImage(event) {
            const preview = document.getElementById('preview');
            const file = event.target.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            } else {
                preview.src = '#';
                preview.style.display = 'none';
            }
        }
    </script>
}