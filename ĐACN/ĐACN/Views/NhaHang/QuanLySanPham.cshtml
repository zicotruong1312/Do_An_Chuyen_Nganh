@model IEnumerable<ĐACN.MonAn>

@{
    ViewBag.Title = "Danh sách sản phẩm";
    ViewBag.Active = "SanPham";
    Layout = "~/Views/Shared/_LayoutNhaHang.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-box-seam"></i> Danh sách sản phẩm</h5>

        <div class="d-flex">
            <input type="text" id="txtSearch" class="form-control me-2" placeholder="Tìm kiếm sản phẩm..." style="width: 250px;">
            <select id="statusFilter" class="form-select me-2" style="width: 180px;">
                <option value="">Tất cả trạng thái</option>
                <option value="1">Đang bán</option>
                <option value="0">Ngừng bán</option>
            </select>
            <a href="@Url.Action("ThemSanPham","NhaHang")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm sản phẩm
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">#</th>
                    <th style="width: 100px;">Hình ảnh</th>
                    <th>Tên món</th>
                    <th>Danh mục</th>
                    <th style="width: 120px;">Giá tiền</th>
                    <th style="width: 120px;">Trạng thái</th>
                    <th style="width: 160px;" class="text-center">Chức năng</th>
                </tr>
            </thead>
            <tbody id="productTable">
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? Url.Content("~/images/monan/no-image.png") : Url.Content("~/images/monan/" + item.HinhAnh))"
                                     class="rounded"
                                     style="width: 60px; height: 60px; object-fit: cover;" />
                            </td>
                            <td>@item.TenMon</td>
                            <td>@item.LoaiMonAn?.TenLoai</td>
                            <td>@string.Format("{0:N0} đ", item.Gia)</td>
                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("ChinhSuaSanPham","NhaHang", new { id = item.MaMon })" class="btn btn-outline-primary btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button class="btn btn-outline-danger btn-sm me-1" onclick="confirmDelete('@item.MaMon')">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <a href="@Url.Action("XemDanhGia","NhaHang", new { id = item.MaMon })" class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-star"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Không có sản phẩm nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Tìm kiếm sản phẩm
    document.getElementById('txtSearch').addEventListener('keyup', function () {
        const keyword = this.value.toLowerCase();
        document.querySelectorAll('#productTable tr').forEach(row => {
            const name = row.cells[2]?.textContent.toLowerCase() || '';
            row.style.display = name.includes(keyword) ? '' : 'none';
        });
    });

    // Lọc theo trạng thái
    document.getElementById('statusFilter').addEventListener('change', function () {
        const val = this.value;
        document.querySelectorAll('#productTable tr').forEach(row => {
            const status = row.querySelector('.badge')?.textContent.trim();
            if (val === '' || (val === '1' && status === 'Đang bán') || (val === '0' && status === 'Ngừng bán')) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });

    // Xóa sản phẩm
    function confirmDelete(id) {
        if (confirm('Bạn có chắc muốn xóa sản phẩm này không?')) {
            window.location.href = '@Url.Action("XoaSanPham", "NhaHang")?id=' + id;
        }
    }
</script>