@model ĐACN.MonAn

@{
    ViewBag.Title = "Thêm sản phẩm";
    ViewBag.Active = "SanPham";
    Layout = "~/Views/Shared/_LayoutNhaHang.cshtml";
}

<h2>Thêm sản phẩm</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@using (Html.BeginForm("ThemSanPham", "NhaHang", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-8">
            <div class="form-group mb-3">
                <label for="TenMon">Tên sản phẩm</label>
                @Html.TextBoxFor(m => m.TenMon, new { @class = "form-control", placeholder = "Nhập tên sản phẩm", id = "TenMon" })
                @Html.ValidationMessageFor(m => m.TenMon, "", new { @class = "text-danger" })
            </div>

            <div class="form-group mb-3">
                <label for="Gia">Giá tiền (VNĐ)</label>
                @Html.TextBoxFor(m => m.Gia, new { @class = "form-control", type = "number", step = "1000", placeholder = "Nhập giá tiền", id = "Gia" })
                @Html.ValidationMessageFor(m => m.Gia, "", new { @class = "text-danger" })
            </div>

            <div class="form-group mb-3">
                <label for="MoTa">Mô tả</label>
                @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 3, placeholder = "Mô tả sản phẩm", id = "MoTa" })
                @Html.ValidationMessageFor(m => m.MoTa, "", new { @class = "text-danger" })
            </div>

            <div class="form-group mb-3">
                <label for="MaLoai">Danh mục</label>
                @Html.DropDownListFor(m => m.MaLoai, (SelectList)ViewBag.MaLoai, "Chọn danh mục", new { @class = "form-control", id = "MaLoai" })
                @Html.ValidationMessageFor(m => m.MaLoai, "", new { @class = "text-danger" })
            </div>

            <div class="form-group mb-3">
                <label>Trạng thái</label><br />
                @Html.RadioButtonFor(m => m.TrangThai, true, new { id = "TrangThaiConHang" }) <label for="TrangThaiConHang">Còn hàng</label>
                @Html.RadioButtonFor(m => m.TrangThai, false, new { id = "TrangThaiHetHang", @class = "ms-3" }) <label for="TrangThaiHetHang">Hết hàng</label>
            </div>

            <button type="submit" class="btn btn-primary">Lưu</button>
            <a href="@Url.Action("QuanLySanPham", "NhaHang")" class="btn btn-secondary">Hủy</a>
        </div>

        <div class="col-md-4">
            <div class="form-group mb-3">
                <label for="HinhAnhFile">Hình ảnh</label>
                <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" id="HinhAnhFile" onchange="previewImage(event)" />
                <br />
                <img id="preview" src="#" alt="Xem trước ảnh" style="display:none; max-width: 100%; border:1px solid #ccc; padding:4px;" />
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function previewImage(event) {
            var preview = document.getElementById('preview');
            if (event.target.files && event.target.files[0]) {
                preview.src = URL.createObjectURL(event.target.files[0]);
                preview.style.display = 'block';
            } else {
                preview.src = '#';
                preview.style.display = 'none';
            }
        }
    </script>
}