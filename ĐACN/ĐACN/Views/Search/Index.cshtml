@model IEnumerable<ĐACN.MonAn>


@{
    ViewBag.Title = "Tìm món ăn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- 🔹 Thanh công cụ tìm kiếm -->
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm p-3 mb-4">
    <div class="container-fluid">
        <!-- Logo -->
        <a class="navbar-brand fw-bold text-danger" href="@Url.Action("Index", "Home")">🍜 FoodFinder</a>

        <!-- Thanh tìm kiếm -->
        <form method="get" action="/Search/Index" class="d-flex mx-auto" style="width: 60%;">
            <input type="text" class="form-control me-2" name="keyword"
                   placeholder="Nhập tên món, nhà hàng hoặc loại món..."
                   value="@ViewBag.Keyword" />
            <button class="btn btn-outline-danger" type="submit">
                <i class="bi bi-search"></i> Tìm
            </button>
        </form>

        <!-- Nút đăng nhập / tài khoản -->
        <div class="d-flex">
            @if (Session["UserID"] == null)
            {
                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary">Đăng nhập</a>
            }
            else
            {
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person"></i> @Session["UserName"]
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="@Url.Action("Logout", "Account")">Đăng xuất</a></li>
                    </ul>
                </div>
            }
        </div>
    </div>
</nav>

<!-- 🔹 Danh sách món ăn -->
<div class="container">
    <h4 class="fw-bold mb-3 text-danger">Kết quả tìm kiếm</h4>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-4">
            <i class="bi bi-emoji-frown fs-2 d-block mb-2"></i>
            Không tìm thấy món ăn nào phù hợp.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var mon in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-truncate">@mon.TenMon</h6>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-shop"></i> @mon.NhaHang?.TenNH
                            </p>
                            <p class="small mb-2 text-secondary">@mon.MoTa</p>
                            <p class="fw-bold text-danger mb-1">
                                @(mon.Gia.HasValue ? mon.Gia.Value.ToString("N0") : "0") ₫
                            </p>

                            <a href="@Url.Action("Details", "MonAn", new { id = mon.MaMon })"
                               class="btn btn-outline-danger w-100">
                                <i class="bi bi-eye"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">