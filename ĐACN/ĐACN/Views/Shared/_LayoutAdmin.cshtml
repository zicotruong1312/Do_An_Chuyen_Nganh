@* /Views/Shared/_LayoutAdmin.cshtml *@
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Admin Dashboard</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex">
        <nav class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">
            <h4 class="text-center mb-4">Quản trị viên</h4>
            <ul class="nav flex-column">
                <li class="nav-item"><a href="@Url.Action("DanhSachCuaHang", "Admin")" class="nav-link text-white">Danh sách cửa hàng</a></li>
                <li class="nav-item"><a href="@Url.Action("CapPhepCuaHang", "Admin")" class="nav-link text-white">Cấp phép cửa hàng</a></li>
                <li class="nav-item"><a href="@Url.Action("DanhSachShipper", "Admin")" class="nav-link text-white">Danh sách người giao hàng</a></li>
                <li class="nav-item"><a href="@Url.Action("CapPhepShipper", "Admin")" class="nav-link text-white">Cấp phép người giao hàng</a></li>
                <li class="nav-item"><a href="@Url.Action("DanhSachNguoiDung", "Admin")" class="nav-link text-white">Danh sách người dùng</a></li>
                <li class="nav-item"><a href="@Url.Action("ThongKe", "Admin")" class="nav-link text-white">Thống kê</a></li>
                <li class="nav-item mt-4"><a href="@Url.Action("DangXuat", "Account")" class="nav-link text-danger">Đăng xuất</a></li>
            </ul>
        </nav>

        <main class="flex-fill p-4">
            @RenderBody()
        </main>
    </div>

    <!-- ✅ Thêm dòng này để render phần scripts từ view con -->
    @RenderSection("scripts", required: false)
</body>
</html>