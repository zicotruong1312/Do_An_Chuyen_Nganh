@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Quản lý cửa hàng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: 100vh;
            background-color: #1e1f21;
            position: fixed;
            top: 0;
            left: 0;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .sidebar .brand {
                text-align: center;
                padding: 15px 0;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                font-size: 1.2rem;
                font-weight: 600;
                background-color: #2c2f33;
            }

        .sidebar-section {
            padding: 10px 0 5px 20px;
            font-size: 0.9rem;
            text-transform: uppercase;
            color: #888;
        }

        .sidebar a {
            display: block;
            padding: 10px 20px;
            color: #ccc;
            text-decoration: none;
            transition: all 0.2s;
        }

            .sidebar a i {
                margin-right: 8px;
            }

            .sidebar a:hover, .sidebar a.active {
                background-color: #0d6efd;
                color: white;
            }

        .sidebar-footer {
            text-align: center;
            padding: 10px;
            font-size: 0.9rem;
            color: #aaa;
        }

        /* Main content */
        .main-content {
            margin-left: 250px;
            padding: 25px;
        }

        .navbar {
            background-color: white;
            box-shadow: 0 1px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div>
            <div class="brand">🍽️ Cửa hàng</div>

            <!-- CỬA HÀNG -->
            <div class="sidebar-section">Cửa hàng</div>
            <a href="@Url.Action("ThongKe","NhaHang")" class="@(ViewBag.Active=="ThongKe"?"active":"")">
                <i class="bi bi-bar-chart"></i> Thống kê
            </a>
            <a href="@Url.Action("ThongTinCuaHang","NhaHang")" class="@(ViewBag.Active=="ThongTin"?"active":"")">
                <i class="bi bi-shop"></i> Thông tin cửa hàng
            </a>

            <!-- SẢN PHẨM -->
            <div class="sidebar-section">Sản phẩm</div>
            <a href="@Url.Action("QuanLySanPham","NhaHang")" class="@(ViewBag.Active=="SanPham"?"active":"")">
                <i class="bi bi-box-seam"></i> Danh sách sản phẩm
            </a>
            <a href="@Url.Action("ThemSanPham","NhaHang")" class="@(ViewBag.Active=="ThemSP"?"active":"")">
                <i class="bi bi-plus-circle"></i> Thêm sản phẩm
            </a>
            <a href="@Url.Action("DanhMuc","NhaHang")" class="@(ViewBag.Active=="DanhMuc"?"active":"")">
                <i class="bi bi-tags"></i> Danh mục
            </a>

            <!-- BÁN HÀNG -->
            <div class="sidebar-section">Bán hàng</div>
            <a href="@Url.Action("DanhSachDonHang","NhaHang")" class="@(ViewBag.Active=="DonHang"?"active":"")">
                <i class="bi bi-receipt"></i> Danh sách đơn hàng
            </a>

            <!-- PHẢN HỒI -->
            <div class="sidebar-section">Phản hồi</div>
            <a href="@Url.Action("PhanHoi","NhaHang")" class="@(ViewBag.Active=="PhanHoi"?"active":"")">
                <i class="bi bi-chat-left-dots"></i> Phản hồi
            </a>
        </div>

        <!-- FOOTER -->
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="text-danger text-decoration-none">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
            <div class="mt-2 text-muted">© 2025 FoodDelivery</div>
        </div>
    </div>

    <!-- Main content -->
    <div class="main-content">
        <nav class="navbar navbar-light mb-4">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5">@ViewBag.Title</span>
                <div class="d-flex align-items-center">
                    <i class="bi bi-bell me-3 fs-5"></i>
                    <i class="bi bi-person-circle fs-4"></i>
                </div>
            </div>
        </nav>

        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
