<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Shipper Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/trangchu.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: 100vh;
            background-color: #1e1f21;
            position: fixed;
            top: 0;
            left: 0;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .sidebar .brand {
                text-align: center;
                padding: 15px 0;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                font-size: 1.2rem;
                font-weight: 600;
                background-color: #2c2f33;
            }

        .sidebar-section {
            padding: 10px 0 5px 20px;
            font-size: 0.9rem;
            text-transform: uppercase;
            color: #888;
        }

        .sidebar a {
            display: block;
            padding: 10px 20px;
            color: #ccc;
            text-decoration: none;
            transition: all 0.2s;
        }

            .sidebar a i {
                margin-right: 8px;
            }

            .sidebar a:hover, .sidebar a.active {
                background-color: #0d6efd;
                color: white;
            }

        .sidebar-footer {
            text-align: center;
            padding: 10px;
            font-size: 0.9rem;
            color: #aaa;
        }

        /* Main content */
        .main-content {
            margin-left: 250px;
            padding: 25px;
        }

        .navbar {
            background-color: white;
            box-shadow: 0 1px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div>
            <div class="brand">🚚 Shipper</div>

            <!-- MENU CHÍNH -->
            <div class="sidebar-section">Menu chính</div>
            <a href="@Url.Action("Index", "Shipper")" class="@(ViewBag.Active == "Index" ? "active" : "")">
                <i class="bi bi-inbox"></i> Đơn chờ nhận
            </a>
            <a href="@Url.Action("Accepted", "Shipper")" class="@(ViewBag.Active == "Accepted" ? "active" : "")">
                <i class="bi bi-check-circle"></i> Đơn đã nhận
            </a>
            <a href="@Url.Action("History", "Shipper")" class="@(ViewBag.Active == "History" ? "active" : "")">
                <i class="bi bi-calendar-check"></i> Lịch sử đơn
            </a>
            <a href="@Url.Action("Income", "Shipper")" class="@(ViewBag.Active == "Income" ? "active" : "")">
                <i class="bi bi-cash-stack"></i> Tổng thu nhập
            </a>

            <!-- TÀI KHOẢN -->
            <div class="sidebar-section">Tài khoản</div>
            <a href="@Url.Action("Profile", "Shipper")" class="@(ViewBag.Active == "Profile" ? "active" : "")">
                <i class="bi bi-person"></i> Thông tin cá nhân
            </a>
        </div>

        <!-- FOOTER -->
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout", "Shipper")" class="text-danger text-decoration-none">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
            <div class="mt-2 text-muted">© 2025 ZFood Delivery</div>
        </div>
    </div>

    <!-- Main content -->
    <div class="main-content">
        <nav class="navbar navbar-light mb-4">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5">@ViewBag.Title</span>
            </div>
        </nav>

        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("scripts", required: false)
</body>
</html>
