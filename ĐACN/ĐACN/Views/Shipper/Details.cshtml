@model ĐACN.Models.DonHangDetailsViewModel
@using System.Linq

@{
    ViewBag.Title = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_LayoutShipper.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Chi tiết đơn hàng @(Model != null ? "#" + Model.MaDon : "")</h2>
                <a href="@Url.Action("Index", "Shipper")" class="btn btn-outline-secondary">Quay lại</a>
            </div>

            @if (Model == null)
            {
                <div class="alert alert-danger">Không tìm thấy đơn hàng.</div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Thông tin đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Mã đơn:</strong> @Model.MaDon
                            </div>
                            <div class="col-md-6">
                                <strong>Trạng thái:</strong>
                                <span class="badge bg-info">@Model.TrangThai</span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Tổng tiền:</strong>
                                <span class="text-danger fw-bold">@String.Format("{0:N0} đ", Model.TongTien ?? 0)</span>
                            </div>
                            <div class="col-md-6">
                                <strong>Thời gian đặt:</strong>
                                @(Model.ThoiGianDat?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                            </div>
                        </div>

                        <hr />

                        <h6 class="mb-3"><i class="fas fa-store"></i> Thông tin nhà hàng</h6>
                        @if (Model.NhaHang != null)
                        {
                            <div class="mb-3 p-3 bg-light rounded">
                                <div class="row">
                                    <div class="col-md-6">
                                        <strong>Tên nhà hàng:</strong> @Model.NhaHang.TenNH
                                    </div>
                                    <div class="col-md-6">
                                        <strong>SĐT:</strong>
                                        @if (!string.IsNullOrEmpty(Model.NhaHang.SDT))
                                        {
                                            <a href="tel:@Model.NhaHang.SDT" class="text-decoration-none">@Model.NhaHang.SDT</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-12">
                                        <strong>Địa chỉ:</strong> @Model.NhaHang.DiaChi
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">Không tìm thấy thông tin nhà hàng.</div>
                        }

                        <hr />

                        <h6 class="mb-3"><i class="fas fa-user"></i> Thông tin khách hàng</h6>
                        @if (Model.KhachHang != null)
                        {
                            <div class="mb-3 p-3 bg-light rounded">
                                <div class="row">
                                    <div class="col-md-6">
                                        <strong>Tên khách hàng:</strong> @Model.KhachHang.TenKH
                                    </div>
                                    <div class="col-md-6">
                                        <strong>SĐT:</strong>
                                        @if (!string.IsNullOrEmpty(Model.KhachHang.SDT))
                                        {
                                            <a href="tel:@Model.KhachHang.SDT" class="text-decoration-none">@Model.KhachHang.SDT</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-12">
                                        <strong>Địa chỉ giao hàng:</strong> @Model.KhachHang.DiaChi
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">Không tìm thấy thông tin khách hàng.</div>
                        }

                        <hr />

                        <h6 class="mb-3"><i class="fas fa-utensils"></i> Chi tiết món ăn</h6>
                        @if (Model.ChiTietMonAn != null && Model.ChiTietMonAn.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 80px;">Hình ảnh</th>
                                            <th>Tên món</th>
                                            <th class="text-center" style="width: 100px;">Số lượng</th>
                                            <th class="text-end" style="width: 120px;">Đơn giá</th>
                                            <th class="text-end" style="width: 120px;">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.ChiTietMonAn)
                                        {
                                            <tr>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                                    {
                                                        <img src="@item.HinhAnh" alt="@item.TenMon" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-secondary text-white text-center d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                            <i class="fas fa-image"></i>
                                                        </div>
                                                    }
                                                </td>
                                                <td>
                                                    <strong>@item.TenMon</strong>
                                                    @if (!string.IsNullOrEmpty(item.MoTa))
                                                    {
                                                        <br />
                                                        <small class="text-muted">@item.MoTa</small>
                                                    }
                                                </td>
                                                <td class="text-center">@item.SoLuong</td>
                                                <td class="text-end">@String.Format("{0:N0} đ", item.DonGia)</td>
                                                <td class="text-end"><strong>@String.Format("{0:N0} đ", item.ThanhTien)</strong></td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="4" class="text-end"><strong>Tổng cộng:</strong></td>
                                            <td class="text-end"><strong class="text-danger">@String.Format("{0:N0} đ", Model.TongTien ?? 0)</strong></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted">Tổng số món: <strong>@Model.ChiTietMonAn.Count</strong> | Tổng số lượng: <strong>@Model.ChiTietMonAn.Sum(x => x.SoLuong)</strong></small>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">Không có món ăn nào trong đơn hàng này.</div>
                        }

                        <hr />

                        @if (string.IsNullOrEmpty(Model.MaShipper))
                        {
                            <div class="mt-3 text-center">
                                @using (Html.BeginForm("Accept", "Shipper", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="maDon" value="@Model.MaDon" />
                                    <button type="submit" class="btn btn-success btn-lg">
                                        <i class="fas fa-check-circle"></i> Nhận đơn
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> Đơn hàng này đã được nhận bởi shipper khác.
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

